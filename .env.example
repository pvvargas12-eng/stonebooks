# Copy this file to .env.local and fill in your Supabase project values.
# Get these from: Supabase dashboard → your project → Settings → API
#
# IMPORTANT:
# - The anon key is safe to expose in the browser — it's the public client key.
# - DO NOT put the service_role key here. That key bypasses Row Level Security
#   and would let anyone with the deployed site read/write everything.

VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOi...your-anon-key-here
